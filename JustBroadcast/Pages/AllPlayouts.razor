@page "/all-playouts"
@using JustBroadcast.Models
@using JustBroadcast.Services
@using JustBroadcast.Shared.Playout
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IAuthService AuthService
@inject ISignalRService SignalRService
@inject NavigationManager Navigation

<div class="all-playouts">
    <div class="ap-topbar">
        <h1>All Playouts</h1>
        @* Suppressed while loading: the count is 0 until data arrives, which would
           otherwise read "0 playouts · 2-up view". *@
        @if (!isLoading)
        {
            <span class="ap-count">@playouts.Count playouts · @ViewLabel</span>
        }
    </div>

    @if (isLoading)
    {
        <div class="loading-container"><DxLoadingPanel Visible="true" Text="Loading playouts..." /></div>
    }
    else
    {
        <div class="ap-grid ap-grid-@GridColumns">
            @foreach (var p in playouts)
            {
                var id = p.Id;
                <PlayoutTile PlayoutId="@id"
                             Name="@(p.Name ?? "Playout")"
                             IsOnline="@IsOnline(id)"
                             Density="@GridColumns"
                             Data="@LiveFor(id)"
                             Outputs="@OutputsFor(id)"
                             Errors="@ErrorsFor(id)"
                             EventLogs="@EventLogsFor(id)"
                             MetricSlots="@MetricSlotsFor(id)"
                             OnMetricTypeChanged="@((t) => OnMetricTypeChanged(id, t.Slot, t.Type))"
                             OnStartStopOutput="StartStopOutput"
                             OnSelect="SelectPlayout" />
            }
        </div>
    }
</div>
